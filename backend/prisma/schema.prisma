generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImageStatus {
  draft
  uploading
  uploaded
  queued
  processing
  accepted
  rejected
  deleted
}

model Image {
  id                  String             @id @default(cuid())
  fileName            String
  originalFileName    String
  contentType         String
  sizeBytes           Int
  status              ImageStatus        @default(draft)
  rejectionReasons    Json?
  storageKey          String?
  previewKey          String?
  normalizedKey       String?
  hash                String?
  width               Int?
  height              Int?
  latestVersionId     String?
  uploadToken         String?
  uploadTokenExpiresAt DateTime?
  deletedAt           DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  versions            ImageVersion[]
  validationResults   ValidationResult[]
  jobs                ProcessingJob[]
  uploadTokens        UploadToken[]
  mediaTokens         MediaToken[]

  @@index([status, createdAt])
  @@index([hash])
}

model ImageVersion {
  id          String   @id @default(cuid())
  imageId     String
  kind        String
  storageKey  String
  mimeType    String
  width       Int?
  height      Int?
  createdAt   DateTime @default(now())
  image       Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId, kind])
}

model ValidationResult {
  id          String   @id @default(cuid())
  imageId     String
  status      ImageStatus
  details     Json
  blurScore   Float?
  hash        String?
  faceData    Json?
  createdAt   DateTime @default(now())
  image       Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId, createdAt])
}

model ProcessingJob {
  id          String   @id @default(cuid())
  imageId     String
  state       String
  attempts    Int      @default(0)
  availableAt DateTime  @default(now())
  lockedAt    DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  image       Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([state, availableAt])
  @@index([imageId, state])
}

model UploadToken {
  token     String   @id
  imageId   String
  expiresAt DateTime
  createdAt DateTime @default(now())
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@index([expiresAt])
}

model MediaToken {
  token     String   @id
  imageId   String
  key       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  image     Image    @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId])
  @@index([expiresAt])
}
